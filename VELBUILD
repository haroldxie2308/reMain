package() {
    install -Dm644 "$srcdir"/translate.qmd \
        "$pkgdir"/home/root/xovi/exthome/qt-resource-rebuilder/translate.qmd
    install -Dm755 "$srcdir"/translate-pdf-cli.aarch64 \
        "$pkgdir"/home/root/xovi/bin/translate-pdf-cli

    install -Dm644 "$srcdir"/LICENSE \
        "$pkgdir"/home/root/.vellum/licenses/$pkgname/LICENSE

    echo "https://github.com/haroldxie2308/reMain" \
        > "$pkgdir"/home/root/.vellum/licenses/$pkgname/SOURCES
}

